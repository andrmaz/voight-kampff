# Copy to `.env` in the project root. The server loads it on startup (via dotenv); already-set
# env vars are not overridden. You can still use direnv or explicit exports if you prefer.
#
# Required for `npm start` / `npm run dev`:
PORT=3000
VOIGHT_DB_PATH=./data/voight.db

# Optional. If set, /sessions/* routes require Authorization: Bearer <token>
# VOIGHT_API_TOKEN=your-secret-token-here

# --- Subject model (interviewee) ---
# Option A: shared keys (no SUBJECT_LLM_*): set LLM_* for the subject.
# Option B: set SUBJECT_LLM_* to use a different subject endpoint than LLM_* (if you also use LLM for something else — here LLM_* is ignored when SUBJECT_LLM_API_KEY is set).
#
# If LLM_API_KEY is set, LLM_BASE_URL and LLM_MODEL are required.
# LLM_API_KEY=sk-or-v1-xxxxxxxx
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini
# LLM_HTTP_REFERER=https://your-app.example
# LLM_APP_TITLE=Voight Kampff

# SUBJECT_LLM_API_KEY=
# SUBJECT_LLM_BASE_URL=https://openrouter.ai/api/v1
# SUBJECT_LLM_MODEL=openai/gpt-4o-mini

# Scoring is deterministic in-process (see run manifest `scoringRubricId` / `scoringRubricVersion`); no analyst LLM.
